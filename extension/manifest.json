{
  "manifest_version": 3,
  "name": "ApplyLog",
  "version": "0.0.1",
  "description": "Automatically track job applications from ATS sites.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "identity", "storage"],
  "host_permissions": [
    "*://*.greenhouse.io/*",
    "*://*.lever.co/*",
    "*://*.ashbyhq.com/*",
    "*://*.myworkdayjobs.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "ApplyLog",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.ashbyhq.com/*",
        "*://*.myworkdayjobs.com/*"
      ],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
